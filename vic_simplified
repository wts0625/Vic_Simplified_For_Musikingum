Baseflow_K_hours = 48.0  # [新增] 地下水出流演进参数 (3天退水期，极大平滑退水线)
THICKNESS  =[0.1, 0.5, 0.5] 

def clean_nodata(arr, nodata_threshold=-1e30, is_categorical=False):
    arr_clean = np.where((arr < nodata_threshold) | (arr > 1e30), np.nan, arr)
    if not is_categorical:
        valid_mean = np.nanmean(arr_clean)
        return np.where(np.isnan(arr_clean), valid_mean, arr_clean)
    return arr_clean

