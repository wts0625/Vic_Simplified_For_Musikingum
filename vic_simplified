print("==============[阶段4] 连续时序推进与分布式等流时线汇流 ==============")
# 初始含水量回调至 55%（解决全局RC过大问题）
state = {'W1': 0.55*W1_max, 'W2': 0.55*W2_max, 'W3': 0.55*W3_max, 
         'Wc': np.zeros_like(W1_max), 'S_store': np.zeros_like(W1_max), 'GW_store': np.zeros_like(W1_max)}

for cycle in range(1, 6):
    for t in range(warmup_steps):
        PET_t = calc_distributed_pet(T_nc[t], RH_nc[t], WS_nc[t], SP_nc[t], SW_nc[t], LW_nc[t], mask, grid_albedo, grid_rough)
        _, _, _, state = vic_runoff_step_distributed(pr_nc[t], PET_t, state)
    print(f" -> 预热循环第 {cycle} 次完成")

# 获取初始蓄水量 (mm)
initial_storage_mm = np.sum((state['W1'] + state['W2'] + state['W3'] + state['Wc'] + state['S_store'] + state['GW_store'])[mask] * area_weights)

# 仅保留严格的 768 时段！抛弃无用的退水尾巴
subbasin_flow = {sid: np.zeros(total_steps) for sid in sub_ids}

# 评价指标累加器 (分离：全期 / 主事件期)
stats = {
    'full': {'P': 0.0, 'E': 0.0, 'Rs': 0.0, 'Rb': 0.0},
    'event': {'P': 0.0, 'E': 0.0, 'Rs': 0.0, 'Rb': 0.0}
}
sub_stats_full = {sid: {'P': 0.0, 'R': 0.0} for sid in sub_ids}
sub_stats_event = {sid: {'P': 0.0, 'R': 0.0} for sid in sub_ids}

for t in range(total_steps):
    if t % 100 == 0: print(f"  [Time] {t}/{total_steps} (连续模拟中...)")
    
    PET_t = calc_distributed_pet(T_nc[t], RH_nc[t], WS_nc[t], SP_nc[t], SW_nc[t], LW_nc[t], mask, grid_albedo, grid_rough)
    Q_surf_routed, Q_base_routed, E_total, state = vic_runoff_step_distributed(pr_nc[t], PET_t, state)
    
    # 严格的面积加权 mm 计算 (解决 33万 mm 的巨大误差)
    P_mean_mm = np.sum(pr_nc[t][mask] * area_weights)
    E_mean_mm = np.sum(E_total[mask] * area_weights)
    Rs_mean_mm = np.sum(Q_surf_routed[mask] * area_weights)
    Rb_mean_mm = np.sum(Q_base_routed[mask] * area_weights)

    # 1. 全期统计
    stats['full']['P'] += P_mean_mm; stats['full']['E'] += E_mean_mm
    stats['full']['Rs'] += Rs_mean_mm; stats['full']['Rb'] += Rb_mean_mm

    # 2. 主事件期统计 (7.27 - 8.5)
    if event_start <= t <= event_end:
        stats['event']['P'] += P_mean_mm; stats['event']['E'] += E_mean_mm
        stats['event']['Rs'] += Rs_mean_mm; stats['event']['Rb'] += Rb_mean_mm

    # 等流时线汇流
    grid_total_m3s = (Q_surf_routed + Q_base_routed) * grid_area / 3600000.0
    for sid in sub_ids:
        mask_sid = (subbasin == sid)
        if not np.any(mask_sid): continue
        
        # 记录子流域全期与事件期数据
        sub_P = np.average(pr_nc[t][mask_sid])
        sub_R = np.average((Q_surf_routed + Q_base_routed)[mask_sid])
        sub_stats_full[sid]['P'] += sub_P; sub_stats_full[sid]['R'] += sub_R
        if event_start <= t <= event_end:
            sub_stats_event[sid]['P'] += sub_P; sub_stats_event[sid]['R'] += sub_R
        
        vols, hrs = grid_total_m3s[mask_sid], grid_travel_hrs[mask_sid]
        T_arrival = t + hrs
        T_int = np.floor(T_arrival).astype(int)
        alpha = T_arrival - T_int
        
        # 边界截断：任何超出 total_steps (768) 的时间汇流将被丢弃 (不要尾巴)
        valid = (T_int + 1 < total_steps) & (~np.isnan(vols))
        if np.any(valid):
            np.add.at(subbasin_flow[sid], T_int[valid], vols[valid] * (1 - alpha[valid]))
            np.add.at(subbasin_flow[sid], T_int[valid] + 1, vols[valid] * alpha[valid])

