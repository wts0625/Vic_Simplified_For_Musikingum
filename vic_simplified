WS_nc = np.maximum(np.where(mask, np.nan_to_num(ds_era['WS'].values[:total_steps]), 1.0), 0.1)
SP_nc = np.where(mask, np.nan_to_num(ds_era['SP'].values[:total_steps]), 1013.25)
SW_nc = np.where(mask, np.nan_to_num(ds_era['SW'].values[:total_steps]), 0.0)
LW_nc = np.where(mask, np.nan_to_num(ds_era['LW'].values[:total_steps]), 0.0)

def calc_distributed_pet(T, RH, WS, SP, SW, LW, mask, albedo_arr, rough_arr):
    sigma, lambda_v = 5.67e-8, 2.45
    e_s = 0.6108 * np.exp((17.27 * T) / (T + 237.3))
    rh_frac = RH / 100.0 if np.nanmax(RH) > 2.0 else RH
    e_a = e_s * rh_frac
    delta = (4098 * e_s) / ((T + 237.3)**2)
    gamma = 0.000665 * (SP / 10.0 if np.nanmax(SP) > 2000 else SP)
    Rn_MJ_h = (SW * (1 - albedo_arr) + LW - sigma * ((T + 273.15)**4)) * 0.0036
    ra = np.clip((np.log(2.0 / np.maximum(rough_arr, 0.001))**2) / (0.41**2 * WS), 20, 300) 
    pet = (delta * Rn_MJ_h + 1.2 * 1.013 * 3600 * (e_s - e_a) / ra / 1000) / (delta + gamma * (1 + 0.34 * WS)) / lambda_v
    return np.where(mask, np.nan_to_num(np.maximum(0, pet)), 0.0)

def vic_runoff_step_distributed(P, PET, state):
    W1, W2, W3, Wc, S_store, GW_store = state['W1'], state['W2'], state['W3'], state['Wc'], state['S_store'], state['GW_store']
    
    Wc += P; P_net = np.maximum(0, Wc - grid_canopy_max); Wc = np.minimum(Wc, grid_canopy_max)
    E_can = np.minimum(Wc, PET); Wc -= E_can; PET_rem = PET - E_can
    
    Wsurf = W1 + W2; Wsurf_max = W1_max + W2_max
    im = (1 + B_INF_VAL) * Wsurf_max
    A = 1 - (1 - np.clip(Wsurf / (Wsurf_max + 1e-6), 0, 0.9999))**(1/(1+B_INF_VAL))
    i0 = im * (1 - (1 - A)**(1+B_INF_VAL))
    
    R_surf = np.where(P_net < im - i0, P_net - Wsurf_max + Wsurf + Wsurf_max * (1 - (i0 + P_net) / (im+1e-6))**(1+B_INF_VAL), P_net - (Wsurf_max - Wsurf))
    R_surf = np.maximum(R_surf, 0); infil = np.maximum(P_net - R_surf, 0)
    
    E_W1 = np.minimum(W1, PET_rem); W1 -= E_W1; PET_rem -= E_W1
    E_W2 = np.minimum(W2, PET_rem); W2 -= E_W2
    
    W1 += infil; over1 = np.maximum(0, W1 - W1_max); W1 -= over1; W2 += over1
    excess_w2 = np.maximum(0, W2 - W2_fc)
    Q_lat = np.minimum(Q_LAT_COEF * Ks * (excess_w2 / (W2_max + 1e-6)), W2); W2 -= Q_lat
    
    perc = np.minimum(0.1 * Ks * (excess_w2 / (W2_max + 1e-6)), W2); W2 -= perc; W3 += perc
    over2 = np.maximum(0, W2 - W2_max); W2 -= over2; W3 += over2
    
    ratio = W3 / (W3_max + 1e-6)
    Q_base_raw = np.where(ratio <= W_S_VAL, (D_S_VAL * DS_MAX / W_S_VAL) * ratio, D_S_VAL * DS_MAX + (DS_MAX - D_S_VAL * DS_MAX) * ((ratio - W_S_VAL) / (1 - W_S_VAL))**2.0)
    Q_base_raw = np.minimum(Q_base_raw, W3); W3 -= Q_base_raw
    over3 = np.maximum(0, W3 - W3_max); W3 -= over3; Q_base_raw += over3
    
    # 【双水库平滑演进：地表慢蓄 + 地下深蓄】
    S_store += (R_surf + Q_lat)
    Q_surf_routed = S_store * (1.0 - np.exp(-1.0 / Grid_K_hours))
    S_store -= Q_surf_routed
    
    # [新增] 地下水出流极其平缓，增加退水阶段斜率
    GW_store += Q_base_raw
    Q_base_routed = GW_store * (1.0 - np.exp(-1.0 / Baseflow_K_hours))
    GW_store -= Q_base_routed

    state['W1'], state['W2'], state['W3'] = np.nan_to_num(W1), np.nan_to_num(W2), np.nan_to_num(W3)
    state['Wc'], state['S_store'], state['GW_store'] = np.nan_to_num(Wc), np.nan_to_num(S_store), np.nan_to_num(GW_store)
    
    return np.nan_to_num(Q_surf_routed), np.nan_to_num(Q_base_routed), np.nan_to_num(E_can + E_W1 + E_W2), state

