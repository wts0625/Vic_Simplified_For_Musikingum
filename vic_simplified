# 3. 坡面/河网双元流速与旅行时间计算 
# ---------------------------------------------------------
print("============== [阶段2] 分布式河网识别与等流时线追踪 ==============")
dz_dy, dz_dx = np.gradient(np.where(mask, dem, np.nan))
slope = np.where(mask, np.clip(np.sqrt((np.nan_to_num(dz_dx)/dx_m)**2 + (np.nan_to_num(dz_dy)/dy_m)**2), 0.0001, 1.0), 0.0001)

R_hydro = np.where(facc > 50, np.clip(0.1 * np.log1p(facc), 0.2, 3.0), 0.02)
n_manning = np.where(facc > 50, 0.035, np.clip(0.04 * (grid_rough ** (1/6.0)), 0.03, 0.15)) 
V_grid = np.where(mask, np.clip((1.0 / n_manning) * (R_hydro**0.667) * np.sqrt(slope), 0.05, 5.0), 0.1)

Grid_K_hours = np.where(mask, np.clip((1000.0 / V_grid) / 3600.0, 0.2, 1.5), 0.5)
grid_travel_hrs = np.full((height, width), np.nan)
with rasterio.open(path_fdir) as src: fdir = src.read(1).astype(np.int16)
dir_to_offset = {1:(0,1), 2:(1,1), 4:(1,0), 8:(1,-1), 16:(0,-1), 32:(-1,-1), 64:(-1,0), 128:(-1,1)}

for sid in sub_ids:
    mask_sid = (subbasin == sid)
    rows, cols = np.where(mask_sid)
    outlets =[]
    for r, c in zip(rows, cols):
        d = fdir[r, c]
        if d in dir_to_offset:
            nr, nc = r + dir_to_offset[d][0], c + dir_to_offset[d][1]
            if not (0 <= nr < height and 0 <= nc < width and subbasin[nr, nc] == sid): outlets.append((r, c))
    if not outlets: outlets.append(np.unravel_index(np.argmin(np.where(mask_sid, dem, np.inf)), dem.shape))
    
    dist = np.full((height, width), np.nan)
    queue = deque(outlets)
    for r, c in outlets: dist[r, c] = 0.0
    
    while queue:
        r, c = queue.popleft()
        for d_val, (dr, dc) in dir_to_offset.items():
            nr, nc = r - dr, c - dc
            if 0 <= nr < height and 0 <= nc < width and mask_sid[nr, nc] and np.isnan(dist[nr, nc]) and fdir[nr, nc] == d_val:
                dist[nr, nc] = dist[r, c] + np.sqrt((dr*dy_m)**2 + (dc*dx_m)**2)
                queue.append((nr, nc))
                
    nan_mask = mask_sid & np.isnan(dist)
    if np.any(nan_mask): 
        dist[nan_mask] = np.sqrt(((np.where(nan_mask)[0] - outlets[0][0])*dy_m)**2 + ((np.where(nan_mask)[1] - outlets[0][1])*dx_m)**2)
    
    grid_travel_hrs[mask_sid] = dist[mask_sid] / (V_grid[mask_sid] * 3600.0)

print("============== [阶段3] 加载气象与纯分布式 VIC 产流机制 ==============")
ds_pr = xr.open_dataset(path_pr); pr_nc = np.where(mask, np.nan_to_num(ds_pr['Precipitation'].values[:total_steps]), 0.0)
