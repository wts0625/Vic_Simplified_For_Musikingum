with rasterio.open(path_dem) as src:
    dem = clean_nodata(src.read(1))
    mask = (dem > -100) & (~np.isnan(dem))
    transform = src.transform
    height, width = dem.shape
    lats = np.array([transform * (0, i) for i in range(height)])[:, 1]
    dx_m, dy_m = 0.01 * 110574, 0.01 * 111320

grid_area = np.zeros((height, width))
for i, lat in enumerate(lats): 
    grid_area[i, :] = (0.01 * 111320 * np.cos(np.radians(lat))) * (0.01 * 110574)
grid_area = np.where(mask, grid_area, 0.0)

# 预先计算面积权重，用于精确核算 mm 量级的水量平衡，避免大数相加崩溃
area_weights = grid_area[mask] / np.sum(grid_area[mask])

with rasterio.open(path_sub) as src:
