def print_metrics(title, P, E, Rs, Rb, dS=None):
    Total_R = Rs + Rb
    print(f"\n>>> [{title}]")
    print(f"  累积降水 (P): {P:.2f} mm")
    print(f"  累积蒸发 (E): {E:.2f} mm")
    print(f"  累积产流 (R_total): {Total_R:.2f} mm (其中地表 {Rs:.2f}, 基流 {Rb:.2f})")
    if dS is not None:
        error = P - E - Total_R - dS
        print(f"  蓄水变量 (ΔS): {dS:.2f} mm")
        print(f"  水量闭合差 (Error): {error:.6f} mm (理论上应趋近于0)")
    print(f"  径流系数 (RC): {Total_R / (P + 1e-6):.3f}")
    print(f"  基流指数 (BFI): {Rb / (Total_R + 1e-6):.3f}")

# 1. 全域水量平衡
final_storage_mm = np.sum((state['W1'] + state['W2'] + state['W3'] + state['Wc'] + state['S_store'] + state['GW_store'])[mask] * area_weights)
delta_S_mm = final_storage_mm - initial_storage_mm
print_metrics("1. 全期宏观水量平衡 (7.15 - 8.15)", **stats['full'], dS=delta_S_mm)
print_metrics("2. 主事件期水量特征 (7.27 - 8.05)", **stats['event'])

# 3. 子流域空间异质性指标
def get_sub_rcs(sub_stats_dict):
    return {sid: v['R']/v['P'] for sid, v in sub_stats_dict.items() if v['P'] > 1.0}

rcs_full = get_sub_rcs(sub_stats_full)
rcs_event = get_sub_rcs(sub_stats_event)

