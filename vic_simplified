    facc = np.nan_to_num(facc)

ds_soil = xr.open_dataset(path_soil)
Wmax =[]
for i, t in enumerate(THICKNESS, 1):
    por = ds_soil[f'porosity_layer{i}'].values
    if por.ndim > 2: por = por[0]
    por_clean = np.where(mask, clean_nodata(por), 0.0)
    Wmax.append(np.where(mask, por_clean * t * 1000.0, 0.0))

W1_max, W2_max, W3_max = Wmax
W2_fc = 0.6 * W2_max
Ks = 10.0 + 20.0 * np.clip(Wmax[0]/(THICKNESS[0]*1000 + 1e-6), 0.2, 0.6)

ds_veg = xr.open_dataset(path_veg)
veg_fraction = np.transpose(np.where(np.isnan(ds_veg['veg_fraction'].values), 0, ds_veg['veg_fraction'].values), (1, 2, 0))
grid_LAI = np.sum(veg_fraction * clean_nodata(ds_veg['LAI'].values).reshape(1, 1, -1), axis=2)
grid_albedo = np.where(mask, np.clip(np.sum(veg_fraction * clean_nodata(ds_veg['albedo'].values).reshape(1, 1, -1), axis=2), 0.1, 0.3), 0.23)
grid_rough = np.where(mask, np.maximum(np.sum(veg_fraction * clean_nodata(ds_veg['roughness_length'].values).reshape(1, 1, -1), axis=2), 0.01), 0.01)
grid_canopy_max = np.where(mask, grid_LAI * 0.2, 0.0)

